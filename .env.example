# Docker ports
MYSQL_PORT=3306
BACKEND_PORT=8081
FRONTEND_PORT=3000

# MySQL
DB_NAME=techstore
DB_USERNAME=techstore
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-root-password
DB_URL=jdbc:mysql://localhost:3306/techstore?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
JPA_DDL_AUTO=update

# JWT: generate with `openssl rand -base64 32`
JWT_SECRET=
JWT_ISSUER=techstore-api
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Browser origins, comma-separated
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_AVATAR_FOLDER=techstore/avatars
CLOUDINARY_PRODUCT_FOLDER=techstore/products
CLOUDINARY_REVIEW_FOLDER=techstore/reviews
CLOUDINARY_CHAT_FOLDER=techstore/chat

# MoMo
MOMO_CREATE_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_REDIRECT_URL=http://localhost:3000/payment/momo/return
MOMO_IPN_URL=https://your-public-domain.example/api/payments/momo/ipn
MOMO_REQUEST_TYPE=captureWallet
MOMO_LANGUAGE=vi

# Frontend
VITE_API_URL=http://localhost:8080
VITE_SUPPORT_USER_ID=1
